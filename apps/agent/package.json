{
  "name": "@sumicom/quicksave",
  "version": "0.3.0",
  "description": "Quicksave agent - remote git control CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingYoung-Sumicom/quicksave.git",
    "directory": "apps/agent"
  },
  "homepage": "https://github.com/KingYoung-Sumicom/quicksave#readme",
  "bugs": {
    "url": "https://github.com/KingYoung-Sumicom/quicksave/issues"
  },
  "keywords": ["git", "cli", "remote", "quicksave"],
  "files": ["dist", "README.md"],
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "branch": "stable"
  },
  "bin": {
    "quicksave": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@sumicom/quicksave-shared": "workspace:*",
    "commander": "^12.0.0",
    "qrcode-terminal": "^0.12.0",
    "simple-git": "^3.22.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
