{
  "name": "quicksave-signaling",
  "version": "0.2.0",
  "description": "Quicksave signaling server for WebRTC connection establishment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/bundle.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.21.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
